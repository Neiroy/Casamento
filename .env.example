# Banco de dados MySQL
DATABASE_URL="mysql://usuario:senha@localhost:3306/wedding_db"

# JWT - use uma string longa e aleatória em produção (OBRIGATÓRIO em produção)
# Nunca commitar o .env; usar variáveis de ambiente no servidor
JWT_SECRET="sua-chave-secreta-jwt-muito-longa-e-segura"

# Mercado Pago - Access Token (produção ou teste)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxx"

# Mercado Pago - Webhook Secret (obtido em Integrações > Webhooks > Configurar)
# Necessário para validar assinatura x-signature nas notificações
MERCADOPAGO_WEBHOOK_SECRET=""

# URL base do site (para webhooks e redirects)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Link PIX fixo - usado para o QR Code
PIX_LINK="https://nubank.com.br/cobrar/1ldui9/69a61fd6-ed7c-467f-9b88-009160760f7a"

# Chave PIX exibida abaixo do QR Code (formato: (XX) XXXXX-XXXX)
PIX_CHAVE="(35) 99707-5707"

# Link do Mercado Pago para pagamento com cartão
MERCADOPAGO_LINK_CARTAO="https://link.mercadopago.com.br/waeinformatica"
